# Normalize line endings: Git stores LF, checkout converts to OS-native.
* text=auto

# Shell scripts ejecutados dentro de contenedores Linux: deben tener LF
# aunque el repo se clone en Windows (CRLF causaría "bad interpreter").
*.sh    text eol=lf

# Archivos de config de contenedores y CI: LF
Dockerfile      text eol=lf
Makefile        text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.toml          text eol=lf
*.conf          text eol=lf
*.json          text eol=lf
*.md            text eol=lf
*.txt           text eol=lf

# Scripts Python/Go/Ruby/Rust/JS: LF
*.py    text eol=lf
*.go    text eol=lf
*.rb    text eol=lf
*.rs    text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.php   text eol=lf

# Scripts Windows: CRLF
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Archivos binarios: sin conversión
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.gz    binary
*.zip   binary
*.tar   binary
*.whl   binary
*.pyc   binary
