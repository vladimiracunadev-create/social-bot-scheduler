# Demo-local template
# Copy to `.env` when you want predictable local credentials and the full lab profile.
# Never expose this mode to the Internet.

STACK_MODE=demo-local
COMPOSE_PROFILES=full
HOST_BIND_IP=127.0.0.1
GENERIC_TIMEZONE=America/Santiago

NO_PUBLIC_POSTING=true
DRY_RUN=true
LOG_LEVEL=INFO

N8N_IMAGE=n8nio/n8n:2.7.5
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_PROXY_HOPS=0
N8N_OWNER_EMAIL=admin@social-bot.local
N8N_OWNER_PASSWORD=SocialBotDemoOnly2026!
N8N_ENCRYPTION_KEY=demo-local-encryption-key-change-before-sharing
N8N_BASIC_AUTH_ACTIVE=false
N8N_SECURE_COOKIE=false

PROMETHEUS_IMAGE=prom/prometheus:v2.54.1
GRAFANA_IMAGE=grafana/grafana:11.2.0
CADVISOR_IMAGE=gcr.io/cadvisor/cadvisor:v0.49.1
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=SocialBotGrafanaDemo2026!

CASE01_DB_PASSWORD=SocialBotCase01Demo2026!
CASE02_DB_PASSWORD=SocialBotCase02Demo2026!
CASE03_DB_PASSWORD=SocialBotCase03Demo2026!
CASE08_DB_PASSWORD=SocialBotCase08Demo2026!
MSSQL_IMAGE=mcr.microsoft.com/mssql/server:2022-CU24-ubuntu-22.04

# Optional edge profile (not enabled by default even in demo-local)
EDGE_PROXY_IMAGE=caddy:2.10.2-alpine
EDGE_BIND_IP=127.0.0.1
EDGE_N8N_HOST=n8n.localhost
EDGE_GRAFANA_HOST=grafana.localhost
EDGE_CASE09_HOST=gateway.localhost
EDGE_BASIC_AUTH_USER=labadmin
EDGE_BASIC_AUTH_HASH=

INTEGRATION_API_KEY=SocialBotLocalKey2026!
GITHUB_TOKEN=
