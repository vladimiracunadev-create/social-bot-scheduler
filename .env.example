# Secure-default template for local use
# Copy to `.env` and replace placeholder values before sharing the lab.

# Runtime mode
STACK_MODE=secure-default
COMPOSE_PROFILES=
HOST_BIND_IP=127.0.0.1
GENERIC_TIMEZONE=America/Santiago

# Safety defaults for origin bots
NO_PUBLIC_POSTING=true
DRY_RUN=true
LOG_LEVEL=INFO

# n8n
N8N_IMAGE=n8nio/n8n:2.7.5
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_PROXY_HOPS=0
N8N_OWNER_EMAIL=change-me@local.invalid
N8N_OWNER_PASSWORD=ChangeMe-Use-A-Unique-Password
N8N_ENCRYPTION_KEY=replace-with-32-or-more-random-characters
N8N_BASIC_AUTH_ACTIVE=false
N8N_SECURE_COOKIE=false

# Observability
PROMETHEUS_IMAGE=prom/prometheus:v2.54.1
GRAFANA_IMAGE=grafana/grafana:11.2.0
CADVISOR_IMAGE=gcr.io/cadvisor/cadvisor:v0.49.1
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ChangeMe-Grafana-Password

# Databases (internal demo credentials, do not reuse in production)
CASE01_DB_PASSWORD=ChangeMe-Case01-DB
CASE02_DB_PASSWORD=ChangeMe-Case02-DB
CASE03_DB_PASSWORD=ChangeMe-Case03-DB
CASE08_DB_PASSWORD=ChangeMe-Case08-DB
MSSQL_IMAGE=mcr.microsoft.com/mssql/server:2022-CU24-ubuntu-22.04

# Optional edge profile (reverse proxy + TLS + basic auth)
# Populate EDGE_BASIC_AUTH_HASH before enabling `--profile edge`
EDGE_PROXY_IMAGE=caddy:2.10.2-alpine
EDGE_BIND_IP=127.0.0.1
EDGE_N8N_HOST=n8n.localhost
EDGE_GRAFANA_HOST=grafana.localhost
EDGE_CASE09_HOST=gateway.localhost
EDGE_BASIC_AUTH_USER=labadmin
EDGE_BASIC_AUTH_HASH=

# Case 09 / outbound integrations
INTEGRATION_API_KEY=ChangeMe-Integration-Key
GITHUB_TOKEN=
